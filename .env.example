# ─── Guardio environment variables ──────────────────────────────────────────
# Copy this file to .env and edit as needed.
# None of these are required to run the app locally.

# API key used to authenticate control endpoints (start/stop/attack/defense).
# Defaults to "devkey" when not set — the frontend uses "devkey" automatically.
GUARDIO_API_KEY=devkey

# Set to "true" to disable all AI features and return stub responses instead.
# Use this if you don't have a Gemini API key — the rest of the app works fine.
GUARDIO_DISABLE_AI=true

# (Optional) Gemini API key for real AI suggestions and incident summaries.
# Only needed if you want live AI responses in the AI Copilot panel.
# GEMINI_API_KEY=your_key_here

# (Optional) Rate limit for the HTTP API (requests per minute per IP).
# Defaults to 120.
# GUARDIO_RATE_LIMIT_PER_MIN=120
