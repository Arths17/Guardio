# ─── Guardio frontend environment variables ──────────────────────────────────
# Copy this file to .env.local to override defaults.
# Everything works without creating this file.

# Backend WebSocket URL (default: ws://localhost:8000/ws)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# API key sent with control requests.
# Must match GUARDIO_API_KEY on the backend (default: devkey).
# NEXT_PUBLIC_API_KEY=devkey
